{
  "name": "cue-research",
  "displayName": "Cue Research - AI 调研助理",
  "version": "1.0.0",
  "description": "5-30 分钟生成专业级深度投资研究报告，支持 7x24 小时智能监控与自动推送",
  "author": {
    "name": "SenseDeal Team",
    "email": "support@sensedeal.ai",
    "url": "https://cuecue.cn"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sensedeal/cue-assistant-skill"
  },
  "license": "MIT",
  "categories": [
    "productivity",
    "research",
    "finance",
    "automation"
  ],
  "tags": [
    "research",
    "analysis",
    "monitoring",
    "ai-agent",
    "investment",
    "report"
  ],
  "screenshots": [
    {
      "url": "https://cdn.cuecue.cn/screenshots/research-progress.png",
      "caption": "研究进度实时展示"
    },
    {
      "url": "https://cdn.cuecue.cn/screenshots/complete-report.png",
      "caption": "报告完成通知与智能推荐"
    },
    {
      "url": "https://cdn.cuecue.cn/screenshots/monitor-dashboard.png",
      "caption": "监控列表管理"
    }
  ],
  "requirements": {
    "openclaw": ">=2026.3.8",
    "node": ">=18.0.0"
  },
  "permissions": [
    "message:send",
    "message:interactive",
    "cron:register",
    "storage:workspace",
    "network:request"
  ],
  "network": {
    "domains": [
      "cuecue.cn",
      "api.tavily.com",
      "api.qveris.ai"
    ],
    "description": "需要访问 CueCue API 进行 AI 推理，Tavily API 进行全网搜索"
  },
  "secrets": [
    {
      "name": "CUECUE_API_KEY",
      "required": true,
      "description": "CueCue 大模型 API Key，用于驱动深度研究"
    },
    {
      "name": "TAVILY_API_KEY",
      "required": false,
      "description": "Tavily 搜索 API Key，用于监控功能的全网检索"
    }
  ],
  "commands": [
    {
      "name": "cue",
      "description": "发起深度调研任务",
      "usage": "/cue <研究问题>",
      "example": "/cue 分析宁德时代竞争优势"
    },
    {
      "name": "ct",
      "description": "查看当前任务状态",
      "usage": "/ct",
      "example": "/ct"
    },
    {
      "name": "cm",
      "description": "查看监控列表",
      "usage": "/cm",
      "example": "/cm"
    },
    {
      "name": "cm add",
      "description": "添加新的监控主题",
      "usage": "/cm add <监控主题>",
      "example": "/cm add 苹果固态电池进展"
    },
    {
      "name": "ch",
      "description": "查看帮助菜单",
      "usage": "/ch",
      "example": "/ch"
    }
  ],
  "backgroundJobs": [
    {
      "name": "monitor-daemon",
      "schedule": "*/30 * * * *",
      "description": "每 30 分钟检查一次监控主题，发现新动态时主动推送"
    }
  ],
  "changelog": "https://github.com/sensedeal/cue-assistant-skill/blob/main/CHANGELOG.md",
  "homepage": "https://cuecue.cn",
  "support": {
    "email": "support@sensedeal.ai",
    "documentation": "https://docs.cuecue.cn/skill"
  }
}
