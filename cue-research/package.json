{
  "name": "@cuebot/cue-research",
  "version": "1.0.0",
  "description": "Cue Research - Professional AI Research Assistant for OpenClaw",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "fs-extra": "^11.2.0"
  },
  "scripts": {
    "test": "node test/test-mode-detector.js",
    "test:all": "npm run test && node test/nlu-test.js",
    "sync": "bash scripts/sync-to-install.sh",
    "dev": "bash scripts/sync-to-install.sh restart",
    "build": "echo 'No build step required (ESM native)'"
  },
  "openclaw": {
    "skill": true,
    "displayName": "Cue Research - AI 调研助理",
    "permissions": [
      "message:send",
      "message:read",
      "message:interactive",
      "cron:register",
      "storage:workspace"
    ],
    "network": {
      "domains": ["cuecue.cn", "api.tavily.com", "api.qveris.ai"]
    },
    "configSchema": {
      "CUECUE_API_KEY": {
        "type": "string",
        "secret": true,
        "required": true,
        "description": "CueCue API Key"
      }
    },
    "commands": [
      {
        "name": "cue",
        "description": "启动深度调研",
        "usage": "/cue <研究主题>",
        "examples": ["/cue 分析宁德时代", "/cue 比亚迪 vs 特斯拉对比"]
      },
      {
        "name": "ct",
        "description": "查看任务状态",
        "usage": "/ct"
      },
      {
        "name": "cancel",
        "description": "取消当前任务",
        "usage": "/cancel"
      },
      {
        "name": "cm",
        "description": "监控管理",
        "usage": "/cm add <监控主题>",
        "examples": ["/cm add 宁德时代财报发布"]
      },
      {
        "name": "cn",
        "description": "查看通知历史",
        "usage": "/cn [天数]"
      },
      {
        "name": "key",
        "description": "配置 API Key",
        "usage": "/key <API Key>"
      },
      {
        "name": "ch",
        "description": "显示帮助菜单",
        "usage": "/ch"
      }
    ],
    "events": {
      "message:received": "onMessageReceived"
    },
    "backgroundJobs": [
      {
        "name": "monitor-daemon",
        "schedule": "*/30 * * * *",
        "action": "runMonitorCheck"
      }
    ],
    "functions": [
      {
        "name": "start_deep_research",
        "description": "当用户要求分析某家公司、行业趋势、财报、股票或寻求投资理财建议时，必须调用此工具来进行深度调研。",
        "parameters": {
          "type": "object",
          "properties": {
            "topic": {
              "type": "string",
              "description": "用户想要调研的具体实体或问题，例如：'宁德时代的竞争优势' 或 '新能源汽车赛道'"
            }
          },
          "required": ["topic"]
        }
      }
    ]
  }
}
